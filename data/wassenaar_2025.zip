  <style>
   input#searchsubmit{
	display:none !important;
   }
   input#search_que{
 	width: 90% !important;
   }

   section.custom_html-6, section.custom_html-4, section.custom_html-3{
    display: none !important;
  }
  body.home section.custom_html-3,
  body.home section.custom_html-4{
    display:block !important;
  }
 .video-link:hover, a.video-link{
    border: none !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    padding: 0px !important;
    background-color: none !important;
    color: #6474bf !important;
  }

.linkedin a img{
   margin-top: -4px;
}

footer[role="contentinfo"] .mobile-footer a.glyphicon-linkedin{
        position: absolute;
        font-size: 2.2em;
        left: 5px;
        top: 50%;
        margin-top: -1.1em;
        padding: 0;
        border: 0;
        border: none !important;
        text-decoration: none;
}

footer[role="contentinfo"] .mobile-footer a.glyphicon-linkedin img{
        width: 31px;
}
  
  .wpcf7-form input[type="text"], .wpcf7-form input[type="email"], .wpcf7-form textarea, .wpcf7-form select {
    margin-top: 2px;
    -webkit-transition: all .2s ease-in 0s;
    -o-transition: all .2s ease-in 0s;
    transition: all .2s ease-in 0s;
    border: 2px solid #ccc;
    border-radius: 5px;
    padding: 6px 12px;
    background-color: #fff;
  }
  .wpcf7-form input[type="text"]:focus, .wpcf7-form input[type="email"]:focus, .wpcf7-form textarea:focus,
  .wpcf7-form input[type="text"]:active, .wpcf7-form input[type="email"]:active, .wpcf7-form textarea:active{
    border:2px solid #9ca8f8 !important;
  }
  
  .wpcf7-form textarea:focus, .wpcf7-form textarea:active{
    outline: none !important;
    box-shadow: none !important;
}

.wpcf7-form input[type="submit"] {
        display: inline-block;
        border: 2px solid #9ca8f8;
        border-radius: 5px;
        color: #9ca8f8;
        font-size: .9em;
        text-transform: uppercase;
        padding: 5px 12px;
        font-weight: 700;
        margin-top: 15px;
        background: #fff;
        -webkit-transition: all .2s ease-in 0s;
        -o-transition: all .2s ease-in 0s;
        transition: all .2s ease-in 0s;
}

.wpcf7-form input[type="submit"]:hover {
        background-color: #9ca8f8;
        color: #fff;
        text-decoration: none;
}

  @media (max-width: 767px) {
     .sidebar{
      position: static !important;
    }
    .video-link{
      display:block !important;
    }

    body.home section.custom_html-6{
      display: block !important;
    }
    body.home section.custom_html-5{
      display: none !important;
    }

    footer[role="contentinfo"] .mobile-footer a.glyphicon-envelope{
        top: 35% !important;
   }
  }

#recruitment-form input[type="file"]{
	/*width: 100% !important;*/
    /*display: none;*/
}

#recruitment-form .custom-file-upload {
    border: 1px solid #ccc;
    display: inline-block;
    padding: 6px 12px;
    cursor: pointer;
}

#recruitment-form label{
	font-weight: normal !important;
}


</style>

